# 市民の声フォーム(/contact)の送信先Discord Webhook URL
# Discordサーバーの「サーバー設定 → 連携サービス → ウェブフック」から新規ウェブフックを作成し、
# 表示されるURLをそのまま設定してください。未設定の場合、フォームは「準備中」として送信を拒否します。
DISCORD_FEEDBACK_WEBHOOK_URL=

# 市民の声フォームの投稿内容をモデレーションするGemini APIキー(Gemini 1.5 Proを使用)
# https://aistudio.google.com/app/apikey から取得してください。未設定の場合もフォームは
# 「準備中」として送信を拒否します(モデレーションなしで投稿が通ることはありません)。
GEMINI_API_KEY=

# 市民活動団体登録(/groups, /applications/group-registration)で使用するPostgreSQLの接続文字列。
# 未設定の場合、これらのページはエラーメッセージを表示します。
# ローカルでPostgreSQL 18を立てる例: podman run -d --name yahari-postgres \
#   -e POSTGRES_USER=yahari -e POSTGRES_PASSWORD=yaharipass -e POSTGRES_DB=yahari \
#   -p 5432:5432 postgres:18-alpine
DATABASE_URL=postgresql://yahari:yaharipass@localhost:5432/yahari
